{
  "name": "@launchapp-dev/ao-memory-mcp",
  "version": "2.0.0",
  "description": "Cognitive memory MCP server for AI agents — semantic search, document RAG, knowledge graph, episodic memory, and hybrid retrieval",
  "type": "module",
  "bin": {
    "ao-memory-mcp": "./src/server.ts"
  },
  "scripts": {
    "start": "node --experimental-strip-types src/server.ts",
    "migrate": "node --experimental-strip-types migrate.ts",
    "build": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.0.0",
    "sqlite-vec": "^0.1.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0"
  }
}
